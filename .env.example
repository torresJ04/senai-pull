# Copy to .env and fill in your values

# Telegram bot (create via @BotFather) - for push notifications
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id


# Optional: run weekly report on this weekday (0=Monday, 6=Sunday)
WEEKLY_REPORT_WEEKDAY=0
WEEKLY_REPORT_HOUR=9

# Optional: interval in minutes for checking watched classes (spots changes)
WATCHED_CLASS_CHECK_INTERVAL=60
